# Copy to next-web/.env.local (never commit .env.local).
# Restart `npm run dev` after changes.

# Required — same DSN as the Python backend Sentry project
NEXT_PUBLIC_SENTRY_DSN=

# Optional tuning (match backend .env if you use one)
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1.0
NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII=true
NEXT_PUBLIC_SENTRY_ENABLE_LOGS=true

# Source map uploads during `next build` (optional)
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=

# Session Replay (optional)
# NEXT_PUBLIC_SENTRY_ENABLE_REPLAY=true

# OpenTelemetry → shared tetrazero-observability stack (see ../observability/README.md)
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_SERVICE_NAME=animemanager-next-web
