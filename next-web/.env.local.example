# Server-only — FastAPI backend on localhost or private LAN (never exposed to browsers)
BACKEND_URL=http://127.0.0.1:8081

# Public URL of this Next.js app (optional; used for server-side WebSocket proxy URLs)
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Set automatically when you launch via `python run.py` (web mode).
# WEB_FRONTEND_URL=http://127.0.0.1:3000
