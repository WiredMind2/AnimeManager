# Backend observability (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry OTLP export — leave unset unless the local Elastic/EDOT stack is running.
# When set without a reachable collector, export failures are filtered from Sentry but still
# add log noise; prefer unset for everyday local dev.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_SERVICE_NAME=animemanager-http
