# Copy to .env and fill in values (never commit .env).
# FastAPI backend reads these when started via run.py / bootstrap.

# Sentry (Python) — https://sentry.io settings → Client Keys (DSN)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_SEND_DEFAULT_PII=true
SENTRY_ENABLE_LOGS=true
SENTRY_PROFILE_SESSION_SAMPLE_RATE=1.0
SENTRY_PROFILE_LIFECYCLE=trace

# Next.js — copy next-web/.env.local.example → next-web/.env.local
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1.0
NEXT_PUBLIC_SENTRY_SEND_DEFAULT_PII=true
NEXT_PUBLIC_SENTRY_ENABLE_LOGS=true
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# OpenTelemetry → shared tetrazero-observability stack (see observability/README.md)
# Start stack: ../tetrazero-observability/docker compose up -d
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_SERVICE_NAME=animemanager-http
OTEL_METRICS_EXPORT_INTERVAL_MS=15000
OTEL_LOG_LEVEL=INFO
