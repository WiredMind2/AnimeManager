# Copy to .env for docker compose (never commit .env).

# --- App ---
APP_URL=http://localhost:3000
WEB_PORT=3000
LIBRARY_PATH=./data/library
ANIMEMANAGER_APPDATA=/srv/Anime Manager
LIBTORRENT_DAEMON_TOKEN=changeme

# Public URLs when behind Caddy + Cloudflare (tetrazero example):
# APP_URL=https://anime.tetrazero.com
# KIBANA_PUBLIC_URL=https://observability.tetrazero.com

# --- Telemetry (shared tetrazero-observability stack) ---
# Start separately: ../tetrazero-observability or scripts/start-elastic-stack.ps1
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_METRICS_EXPORT_INTERVAL_MS=15000
OTEL_LOG_LEVEL=INFO

# --- Optional Sentry (independent of Elastic) ---
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
